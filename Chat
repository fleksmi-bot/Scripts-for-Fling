-- НЕВИДИМЫЙ ЮНИКОД МАРКЕР (Zero-Width Space)
local INVISIBLE_PREFIX = "\u{200B}\u{200C}\u{200D}"

-- Функция вывода сообщений в кастомное окно
local function appendMessage(senderName, messageText)
    -- Очищаем текст сообщения от невидимого префикса, чтобы он не ломал отображение
    if messageText:sub(1, #INVISIBLE_PREFIX) == INVISIBLE_PREFIX then
        messageText = messageText:sub(#INVISIBLE_PREFIX + 1)
    end

    local MessageLabel = Instance.new("TextLabel")
    MessageLabel.Size = UDim2.new(1, 0, 0, 20)
    MessageLabel.BackgroundTransparency = 1
    MessageLabel.Font = Enum.Font.SourceSansBold
    MessageLabel.TextSize = 16
    MessageLabel.TextXAlignment = Enum.TextXAlignment.Left
    MessageLabel.TextWrapped = true
    
    -- Включаем поддержку HTML-тегов цветов (КРИТИЧЕСКИЙ ИСПРАВЛЕННЫЙ ПУНКТ)
    MessageLabel.RichText = true 
    
    if senderName == LocalPlayer.Name then
        MessageLabel.Text = "<font color='#55FF55'>" .. senderName .. ":</font> <font color='#FFFFFF'>" .. messageText .. "</font>"
    else
        MessageLabel.Text = "<font color='#FF5555'>" .. senderName .. ":</font> <font color='#FFFFFF'>" .. messageText .. "</font>"
    end
    
    MessageLabel.TextStrokeTransparency = 0.8
    MessageLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    MessageLabel.Parent = ScrollingFrame
    
    -- Корректный перерасчет высоты строки на мобильных устройствах
    task.wait(0.05)
    MessageLabel.Size = UDim2.new(1, 0, 0, MessageLabel.TextBounds.Y + 2)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
    ScrollingFrame.CanvasPosition = Vector2.new(0, UIListLayout.AbsoluteContentSize.Y)
end

-- Логика отправки сообщений
TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed and TextBox.Text ~= "" then
        local msg = TextBox.Text
        TextBox.Text = ""
        
        local hiddenPayload = INVISIBLE_PREFIX .. msg
        
        -- Проверяем актуальную систему чата и отправляем пакет данных
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            local channel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if channel then
                channel:SendAsync(hiddenPayload)
            end
        elseif LegacyChatEvent then
            LegacyChatEvent:FireServer(hiddenPayload, "All")
        end
    end
end)

-- Слушатель входящих сообщений для Новой системы чата (TextChatService)
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.OnIncomingMessage = function(message)
        if message.Text:sub(1, #INVISIBLE_PREFIX) == INVISIBLE_PREFIX then
            local cleanMessage = message.Text:sub(#INVISIBLE_PREFIX + 1)
            local sender = message.TextSource and message.TextSource.Name or "Unknown"
            
            appendMessage(sender, cleanMessage)
            
            -- Скрываем текст из стандартного окна чата, оставляя пустую строку
            local properties = Instance.new("TextChatMessageProperties")
            properties.Text = " "
            return properties
        end
    end
end

-- Универсальный слушатель чата (работает и на старых, и на новых плейсах через событие .Chatted)
local function hookPlayer(player)
    player.Chatted:Connect(function(msg)
        if msg:sub(1, #INVISIBLE_PREFIX) == INVISIBLE_PREFIX then
            -- Если это TextChatService, OnIncomingMessage уже обработал его, чтобы избежать дублей
            if TextChatService.ChatVersion ~= Enum.ChatVersion.TextChatService then
                local cleanMessage = msg:sub(#INVISIBLE_PREFIX + 1)
                appendMessage(player.Name, cleanMessage)
            end
        end
    end)
end

Players.PlayerAdded:Connect(hookPlayer)
for _, player in ipairs(Players:GetPlayers()) do
    hookPlayer(player)
end

