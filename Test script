-- ========== UTILS ==========
local Utils = {}

function Utils:CreateRoundedFrame(parent, properties)
    local frame = Instance.new("Frame")
    frame.Name = properties.Name or "RoundedFrame"
    frame.Size = properties.Size or UDim2.new(0, 200, 0, 200)
    frame.Position = properties.Position or UDim2.new(0, 0, 0, 0)
    frame.BackgroundColor3 = properties.BackgroundColor3 or Color3.fromRGB(66, 66, 66)
    frame.BorderSizePixel = 0
    frame.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, properties.CornerRadius or 8)
    corner.Parent = frame

    return frame
end

-- Создаёт кликабельную кнопку (TextButton) с закруглениями
function Utils:CreateButton(parent, properties)
    local button = Instance.new("TextButton")
    button.Name = properties.Name or "Button"
    button.Size = properties.Size or UDim2.new(0, 100, 0, 40)
    button.Position = properties.Position or UDim2.new(0, 0, 0, 0)
    button.BackgroundColor3 = properties.BackgroundColor3 or Color3.fromRGB(90, 90, 90)
    button.BorderSizePixel = 0
    button.AutoButtonColor = true
    button.Text = properties.Text or "Button"
    button.TextColor3 = properties.TextColor3 or Color3.fromRGB(255, 255, 255)
    button.TextScaled = properties.TextScaled ~= false -- default true
    button.Font = properties.Font or Enum.Font.GothamBold
    button.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, properties.CornerRadius or 6)
    corner.Parent = button

    if properties.Callback then
        button.MouseButton1Click:Connect(properties.Callback)
    end

    return button
end

function Utils:AnimateIn(instance, duration)
    duration = duration or 0.25
    instance.Visible = true
    local goal = {}
    -- если у элемента есть BackgroundTransparency - анимируем её, иначе альфа-видимость
    goal.BackgroundTransparency = 0
    local tween = TweenService:Create(instance, TweenInfo.new(duration, Enum.EasingStyle.Quad), goal)
    tween:Play()
    return tween
end

function Utils:AnimateOut(instance, duration)
    duration = duration or 0.2
    local goal = {BackgroundTransparency = 1}
    local tween = TweenService:Create(instance, TweenInfo.new(duration, Enum.EasingStyle.Quad), goal)
    tween:Play()
    tween.Completed:Wait()
    instance.Visible = false
    return tween
end

-- ========== FLOATING BUTTON ==========
local FloatingButton = {}
FloatingButton.__index = FloatingButton

function FloatingButton.new(parent)
    local self = setmetatable({}, FloatingButton)
    self.parent = parent
    self.isOpen = false
    self.onToggle = nil

    -- Контейнер чтобы удобно управлять тенью и кнопкой вместе
    self.container = Instance.new("Frame")
    self.container.Name = "FloatingButtonContainer"
    self.container.Size = UDim2.new(0, 60, 0, 60)
    self.container.Position = UDim2.new(1, -80, 1, -80)
    self.container.BackgroundTransparency = 1
    self.container.BorderSizePixel = 0
    self.container.Parent = parent

    -- Тень (снизу)
    local shadow = Instance.new("Frame")
    shadow.Name = "Shadow"
    shadow.Size = UDim2.new(1, 0, 1, 0)
    shadow.Position = UDim2.new(0, 4, 0, 4)
    shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    shadow.BorderSizePixel = 0
    shadow.BackgroundTransparency = 0.6
    shadow.ZIndex = 0
    shadow.Parent = self.container
    local shadowCorner = Instance.new("UICorner"); shadowCorner.CornerRadius = UDim.new(0, 30); shadowCorner.Parent = shadow

    -- Кнопка (TextButton)
    self.button = Instance.new("TextButton")
    self.button.Name = "FloatingButton"
    self.button.Size = UDim2.new(1, 0, 1, 0)
    self.button.Position = UDim2.new(0, 0, 0, 0)
    self.button.BackgroundColor3 = Color3.fromRGB(66, 150, 255)
    self.button.BorderSizePixel = 0
    self.button.AutoButtonColor = true
    self.button.Text = "☎"
    self.button.Font = Enum.Font.GothamBold
    self.button.TextScaled = true
    self.button.TextColor3 = Color3.fromRGB(255,255,255)
    self.button.ZIndex = 2
    self.button.Parent = self.container
    local btnCorner = Instance.new("UICorner"); btnCorner.CornerRadius = UDim.new(0, 30); btnCorner.Parent = self.button

    -- drag vars
    self.dragging = false
    self.dragInput = nil
    self.dragStart = nil
    self.startPos = nil
    self.clickThreshold = 6 -- пикселей движения, чтобы отличить клик от драг

    -- Input handling
    self.button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            self.dragging = true
            self.dragStart = input.Position
            self.startPos = self.container.Position

            -- отслеживаем, когда этот input закончится
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    -- решение о клике/перетаскивании в InputEnded обработчике ниже
                    self.dragging = false
                end
            end)
        elseif input.UserInputType == Enum.UserInputType.MouseMovement then
            -- nothing
        end
    end)

    self.button.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            self.dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == self.dragInput and self.dragStart and self.startPos then
            local delta = input.Position - self.dragStart
            local newX = self.startPos.X.Offset + delta.X
            local newY = self.startPos.Y.Offset + delta.Y
            -- ограничиваем в пределах экрана (прибавляем запас)
            local screen = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or viewportSize
            local w = self.container.AbsoluteSize.X
            local h = self.container.AbsoluteSize.Y
            newX = math.clamp(newX, 6, screen.X - w - 6)
            newY = math.clamp(newY, 6, screen.Y - h - 6)
            self.container.Position = UDim2.new(0, newX, 0, newY)
        end
    end)

    -- Отпуск кнопки: определяем клик или завершение перетаскивания и делаем snap
    self.button.InputEnded:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if self.dragStart then
                local moved = (input.Position - self.dragStart).Magnitude
                if moved <= self.clickThreshold then
                    -- считаем кликом
                    self:Toggle()
                else
                    -- snap к краю экрана
                    self:SnapToEdge()
                end
            else
                -- на случай, если нет dragStart - просто toggle
                self:Toggle()
            end

            -- сброс состояния
            self.dragStart = nil
            self.dragInput = nil
            self.startPos = nil
            self.dragging = false
        end
    end)

    return self
end

function FloatingButton:AnimateColor(newColor)
    local tween = TweenService:Create(self.button, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = newColor})
    tween:Play()
end

function FloatingButton:Toggle()
    self.isOpen = not self.isOpen
    if self.onToggle then
        self.onToggle(self.isOpen)
    end
    local newColor = self.isOpen and Color3.fromRGB(200, 100, 255) or Color3.fromRGB(66, 150, 255)
    self:AnimateColor(newColor)
end

-- Snap: привязка к левой или правой стороне с анимацией
function FloatingButton:SnapToEdge()
    local screen = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or viewportSize
    local absPos = self.container.AbsolutePosition
    local absSize = self.container.AbsoluteSize
    local centerX = absPos.X + absSize.X/2
    local targetX = 10
    if centerX > screen.X/2 then
        targetX = screen.X - absSize.X - 10
    end
    local targetPos = UDim2.new(0, targetX, 0, math.clamp(absPos.Y, 6, screen.Y - absSize.Y - 6))
    TweenService:Create(self.container, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
end

function FloatingButton:OnToggle(callback)
    self.onToggle = callback
end

function FloatingButton:Show() self.container.Visible = true end
function FloatingButton:Hide() self.container.Visible = false end

-- ========== MAIN MENU ==========
local MainMenu = {}
MainMenu.__index = MainMenu

function MainMenu.new(parent)
    local self = setmetatable({}, MainMenu)
    self.parent = parent
    self.isOpen = false
    self:CreateMenu()
    return self
end

