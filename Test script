local Utils = {}

-- Создание панели с закругленными углами
function Utils:CreateRoundedFrame(parent, properties)
    local frame = Instance.new("Frame")
    frame.Name = properties.Name or "RoundedFrame"
    frame.Size = properties.Size or UDim2.new(0, 200, 0, 200)
    frame.Position = properties.Position or UDim2.new(0, 0, 0, 0)
    frame.BackgroundColor3 = properties.BackgroundColor3 or Color3.fromRGB(66, 66, 66)
    frame.BorderSizePixel = 0
    frame.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, properties.CornerRadius or 8)
    corner.Parent = frame

    return frame
end

-- Создание кнопки
function Utils:CreateButton(parent, properties)
    local button = self:CreateRoundedFrame(parent, {
        Name = properties.Name or "Button",
        Size = properties.Size or UDim2.new(0, 100, 0, 40),
        Position = properties.Position or UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = properties.BackgroundColor3 or Color3.fromRGB(90, 90, 90),
        CornerRadius = 6
    })

    local textLabel = Instance.new("TextLabel")
    textLabel.Name = "TextLabel"
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Text = properties.Text or "Button"
    textLabel.Parent = button

    if properties.Callback then
        button.MouseButton1Click:Connect(properties.Callback)
    end

    return button
end

-- Анимация появления
function Utils:AnimateIn(instance, duration)
    duration = duration or 0.3
    instance.BackgroundTransparency = 1
    
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(
        duration,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )
    
    local tween = tweenService:Create(instance, tweenInfo, {BackgroundTransparency = 0})
    tween:Play()
    
    return tween
end

-- ========== ПЛАВАЮЩАЯ КНОПКА ==========
local FloatingButton = {}
FloatingButton.__index = FloatingButton

function FloatingButton.new(parent)
    local self = setmetatable({}, FloatingButton)
    
    self.parent = parent
    self.isDragging = false
    self.dragStart = nil
    self.dragStartPos = nil
    self.onToggle = nil
    self.isOpen = false
    
    self:CreateButton()
    
    return self
end

function FloatingButton:CreateButton()
    self.button = Utils:CreateRoundedFrame(self.parent, {
        Name = "FloatingButton",
        Size = UDim2.new(0, 60, 0, 60),
        Position = UDim2.new(1, -80, 1, -80),
        BackgroundColor3 = Color3.fromRGB(66, 150, 255),
        CornerRadius = 30
    })
    
    local shadow = Instance.new("Frame")
    shadow.Name = "Shadow"
    shadow.Size = UDim2.new(1, 0, 1, 0)
    shadow.Position = UDim2.new(0, 2, 0, 2)
    shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    shadow.BorderSizePixel = 0
    shadow.ZIndex = 0
    
    local shadowCorner = Instance.new("UICorner")
    shadowCorner.CornerRadius = UDim.new(0, 30)
    shadowCorner.Parent = shadow
    
    shadow.Parent = self.button
    
    local icon = Instance.new("TextLabel")
    icon.Name = "Icon"
    icon.Size = UDim2.new(1, 0, 1, 0)
    icon.BackgroundTransparency = 1
    icon.TextColor3 = Color3.fromRGB(255, 255, 255)
    icon.TextScaled = true
    icon.Font = Enum.Font.GothamBold
    icon.Text = "☎"
    icon.ZIndex = 2
    icon.Parent = self.button
    
    self.button.MouseButton1Click:Connect(function()
        if not self.isDragging then
            self:Toggle()
        end
    end)
    
    self:SetupDragging()
end

function FloatingButton:SetupDragging()
    local UserInputService = game:GetService("UserInputService")
    local mouse = game.Players.LocalPlayer:GetMouse()
    
    self.button.MouseButton1Down:Connect(function()
        self.isDragging = true
        self.dragStart = mouse.Hit.Position
        self.dragStartPos = self.button.Position
    end)
    
    UserInputService.InputChanged:Connect(function(input, gameProcessed)
        if gameProcessed or not self.isDragging then return end
        
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = mouse.X - (self.dragStartPos.X.Offset or 0)
            local deltaY = mouse.Y - (self.dragStartPos.Y.Offset or 0)
            
            self.button.Position = UDim2.new(
                0, 
                self.dragStartPos.X.Offset + delta,
                0, 
                self.dragStartPos.Y.Offset + deltaY
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.isDragging = false
        end
    end)
end

function FloatingButton:Toggle()
    self.isOpen = not self.isOpen
    
    if self.onToggle then
        self.onToggle(self.isOpen)
    end
    
    local newColor = self.isOpen and Color3.fromRGB(200, 100, 255) or Color3.fromRGB(66, 150, 255)
    self:AnimateColor(newColor)
end

function FloatingButton:AnimateColor(newColor)
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(
        0.2,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )
    
    local tween = tweenService:Create(self.button, tweenInfo, {BackgroundColor3 = newColor})
    tween:Play()
end

function FloatingButton:OnToggle(callback)
    self.onToggle = callback
end

