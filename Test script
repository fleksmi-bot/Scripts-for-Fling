    self.menuPanel = Utils:CreateRoundedFrame(self.parent, {
        Name = "MainMenu",
        Size = UDim2.new(0, 420, 0, 520),
        Position = UDim2.new(0.5, -210, 0.5, -260),
        BackgroundColor3 = Color3.fromRGB(40, 40, 40),
        CornerRadius = 12
    })
    self.menuPanel.Visible = false
    self.menuPanel.BackgroundTransparency = 0.05

    local closeButton = Utils:CreateButton(self.menuPanel, {
        Name = "CloseButton",
        Size = UDim2.new(0, 34, 0, 34),
        Position = UDim2.new(1, -46, 0, 12),
        BackgroundColor3 = Color3.fromRGB(200, 50, 50),
        Text = "✕",
        CornerRadius = 8
    })
    closeButton.MouseButton1Click:Connect(function() self:Close() end)

    local title = Instance.new("TextLabel")
    title.Name = "Title"; title.Size = UDim2.new(1, -70, 0, 40); title.Position = UDim2.new(0, 16, 0, 8)
    title.BackgroundTransparency = 1; title.TextColor3 = Color3.fromRGB(255,255,255)
    title.TextScaled = true; title.Font = Enum.Font.GothamBold; title.Text = "Главное Меню"
    title.Parent = self.menuPanel

    local tabContainer = Utils:CreateRoundedFrame(self.menuPanel, {
        Name = "TabContainer", Size = UDim2.new(1, -30, 1, -88), Position = UDim2.new(0, 15, 0, 56),
        BackgroundColor3 = Color3.fromRGB(50,50,50), CornerRadius = 10
    })

    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Name = "ScrollFrame"; scrollFrame.Size = UDim2.new(1, 0, 1, 0)
    scrollFrame.BackgroundTransparency = 1; scrollFrame.ScrollBarThickness = 8
    scrollFrame.Parent = tabContainer

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 10)
    listLayout.Parent = scrollFrame

    self.scrollFrame = scrollFrame

    local options = { "💰 Coins", "🛍 Shop", "🧸 Toys", "🗑 Destroy Toys", "⭐ Favorites", "⚙ Settings" }
    for _, txt in ipairs(options) do
        local opt = Utils:CreateButton(scrollFrame, {
            Name = txt, Size = UDim2.new(1, -20, 0, 52), Position = UDim2.new(0, 10, 0, 0),
            BackgroundColor3 = Color3.fromRGB(66,66,66), Text = txt
        })
        opt.Parent = scrollFrame
    end
end

function MainMenu:Open()
    if not self.menuPanel.Visible then
        self.menuPanel.BackgroundTransparency = 1
        self.menuPanel.Visible = true
        Utils:AnimateIn(self.menuPanel, 0.24)
    end
    self.isOpen = true
end

function MainMenu:Close()
    if self.menuPanel.Visible then
        -- можно использовать AnimateOut, но для простоты просто скрываем
        self.menuPanel.Visible = false
    end
    self.isOpen = false
end

